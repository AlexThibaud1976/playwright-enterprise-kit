# ────────────────────────────────────────────────────────────────────────────
# Playwright Enterprise Kit - Environment variables
#
# Copy this file: cp .env.example .env
# DO NOT commit .env to the repository (it is in .gitignore)
# ────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000

# ── Playwright ───────────────────────────────────────────────────────────────
HEADLESS=false
TEST_TIMEOUT=60000

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USER=your.email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=MYPROJECT

# ── Xray Cloud ───────────────────────────────────────────────────────────────
XRAY_CLIENT_ID=your_xray_client_id
XRAY_CLIENT_SECRET=your_xray_client_secret
XRAY_ENDPOINT=xray.cloud.getxray.app

# ── Jira custom fields (optional) ───────────────────────────────────────────
# Retrieve IDs via: scripts/get-custom-field-ids.ps1
# Format : customfield_XXXXX
# JIRA_CUSTOM_FIELD_OS=customfield_10100
# JIRA_CUSTOM_FIELD_OS_VERSION=customfield_10101
# JIRA_CUSTOM_FIELD_BROWSER=customfield_10102
# JIRA_CUSTOM_FIELD_BROWSER_VERSION=customfield_10103
# JIRA_CUSTOM_FIELD_TEST_SCOPE=customfield_10104

# ── Confluence (optional) ────────────────────────────────────────────────────
# CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
# CONFLUENCE_USER=your.email@example.com
# CONFLUENCE_API_TOKEN=your_confluence_api_token
# CONFLUENCE_SPACE_KEY=QA
# CONFLUENCE_PAGE_TITLE=Test Execution Dashboard
# CONFLUENCE_PARENT_PAGE_ID=

# ── Test users ────────────────────────────────────────────────────────────────
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=password123
