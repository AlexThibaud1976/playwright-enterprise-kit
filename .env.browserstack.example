# ────────────────────────────────────────────────────────────────────────────
# Playwright Enterprise Kit - BrowserStack configuration
#
# Copy this file: cp .env.browserstack.example .env.browserstack
# DO NOT commit .env.browserstack to the repository (it is in .gitignore)
# ────────────────────────────────────────────────────────────────────────────

# ── BrowserStack credentials (required) ─────────────────────────────────────────
BROWSERSTACK_USERNAME=your_username
BROWSERSTACK_ACCESS_KEY=your_access_key

# ── Project name (displayed in the BrowserStack dashboard) ───────────────────
BS_PROJECT_NAME=My Project

# ── Desktop configuration ────────────────────────────────────────────────────
# OS : Windows | OS X
BS_OS=Windows

# Windows versions : 7, 8, 8.1, 10, 11
# Mac versions     : Catalina, Big Sur, Monterey, Ventura, Sonoma, Sequoia
BS_OS_VERSION=11

# Navigateurs : chrome, firefox, safari, edge, chromium
BS_BROWSER=chrome

# Versions: latest, latest-1, latest-2, or specific version (e.g. 131)
BS_BROWSER_VERSION=latest

# ── Parallelism ──────────────────────────────────────────────────────────────
BS_WORKERS=5

# ── Build name (auto-generated if not set) ─────────────────────────────────────
# BROWSERSTACK_BUILD_NAME=My Custom Build Name

# ─────────────────────────────────────────────────────────────────────────────
# Ready-to-use configuration examples:
# ─────────────────────────────────────────────────────────────────────────────
#
# Windows 11 + Chrome latest
# BS_OS=Windows | BS_OS_VERSION=11 | BS_BROWSER=chrome | BS_BROWSER_VERSION=latest
#
# Windows 10 + Firefox latest
# BS_OS=Windows | BS_OS_VERSION=10 | BS_BROWSER=firefox | BS_BROWSER_VERSION=latest
#
# macOS Sonoma + Safari latest
# BS_OS=OS X | BS_OS_VERSION=Sonoma | BS_BROWSER=safari | BS_BROWSER_VERSION=latest
#
# macOS Sequoia + Edge latest
# BS_OS=OS X | BS_OS_VERSION=Sequoia | BS_BROWSER=edge | BS_BROWSER_VERSION=latest
# ─────────────────────────────────────────────────────────────────────────────
