# ────────────────────────────────────────────────────────────────────────────
# Playwright Enterprise Kit - Configuration BrowserStack
#
# Copier ce fichier : cp .env.browserstack.example .env.browserstack
# NE PAS committer .env.browserstack dans le dépôt (il est dans .gitignore)
# ────────────────────────────────────────────────────────────────────────────

# ── Credentials BrowserStack (obligatoires) ───────────────────────────────────
BROWSERSTACK_USERNAME=your_username
BROWSERSTACK_ACCESS_KEY=your_access_key

# ── Nom du projet (affiché dans le dashboard BrowserStack) ───────────────────
BS_PROJECT_NAME=My Project

# ── Configuration desktop ────────────────────────────────────────────────────
# OS : Windows | OS X
BS_OS=Windows

# Versions Windows : 7, 8, 8.1, 10, 11
# Versions Mac     : Catalina, Big Sur, Monterey, Ventura, Sonoma, Sequoia
BS_OS_VERSION=11

# Navigateurs : chrome, firefox, safari, edge, chromium
BS_BROWSER=chrome

# Versions : latest, latest-1, latest-2, ou version spécifique (ex: 131)
BS_BROWSER_VERSION=latest

# ── Parallélisation ──────────────────────────────────────────────────────────
BS_WORKERS=5

# ── Nom du build (auto-généré si non défini) ─────────────────────────────────
# BROWSERSTACK_BUILD_NAME=My Custom Build Name

# ─────────────────────────────────────────────────────────────────────────────
# Exemples de configurations prêtes à l'emploi :
# ─────────────────────────────────────────────────────────────────────────────
#
# Windows 11 + Chrome latest
# BS_OS=Windows | BS_OS_VERSION=11 | BS_BROWSER=chrome | BS_BROWSER_VERSION=latest
#
# Windows 10 + Firefox latest
# BS_OS=Windows | BS_OS_VERSION=10 | BS_BROWSER=firefox | BS_BROWSER_VERSION=latest
#
# macOS Sonoma + Safari latest
# BS_OS=OS X | BS_OS_VERSION=Sonoma | BS_BROWSER=safari | BS_BROWSER_VERSION=latest
#
# macOS Sequoia + Edge latest
# BS_OS=OS X | BS_OS_VERSION=Sequoia | BS_BROWSER=edge | BS_BROWSER_VERSION=latest
# ─────────────────────────────────────────────────────────────────────────────
